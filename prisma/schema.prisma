generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  role      String   @default("SETTER")
  phone     String?
  avatarUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Relación closer -> setters
  closerId Int?
  closer   User?  @relation("CloserToSetters", fields: [closerId], references: [id])
  setters  User[] @relation("CloserToSetters")

  parcelsTaken   Parcel[]       @relation("ParcelSetter")
  visitsAsSetter Visit[]        @relation("VisitSetter")
  visitsAsCloser Visit[]        @relation("VisitCloser")
  slots          CloserSlot[]
  messages       ChatMessage[]
  notifications  Notification[]
  weeklyPatterns WeeklyPattern[]
  userBadges     UserBadge[]
  reassignFrom   SlotReassignment[] @relation("ReassignFrom")
  reassignTo     SlotReassignment[] @relation("ReassignTo")
}

model CloserSlot {
  id        Int      @id @default(autoincrement())
  closerId  Int
  closer    User     @relation(fields: [closerId], references: [id], onDelete: Cascade)
  startAt   DateTime
  endAt     DateTime
  isBooked  Boolean  @default(false)
  isWorkday Boolean  @default(true)
  visitId   Int?     @unique
  visit     Visit?   @relation(fields: [visitId], references: [id])
  reassignments SlotReassignment[]
}

model Parcel {
  id          String       @id @default(uuid())
  externalId  String?      @unique
  address     String
  ownerName   String?
  geometry    String
  territory   String       @default("Florida")
  status      String       @default("AVAILABLE")
  metadata    String? // JSON con datos extra (roofAge, utility, solarPotential)

  setterId Int?
  setter   User?   @relation("ParcelSetter", fields: [setterId], references: [id])

  visits Visit[]
}

model Visit {
  id          Int        @id @default(autoincrement())
  parcelId    String
  parcel      Parcel     @relation(fields: [parcelId], references: [id])
  setterId    Int
  setter      User       @relation("VisitSetter", fields: [setterId], references: [id])
  closerId    Int?
  closer      User?      @relation("VisitCloser", fields: [closerId], references: [id])
  stage       String     @default("IN_PROGRESS")
  outcome     String?
  scheduledAt DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime   @default(now())

  objections       VisitObjection[]
  closerObjections VisitCloserObjection[]
  bill             Bill?
  chatRoom         ChatRoom?
  slot             CloserSlot?
  projects         VisitProject[]
  projectDetails   ProjectDetails?
}

// Tipos de proyectos disponibles
model ProjectType {
  id          Int            @id @default(autoincrement())
  name        String         @unique
  description String?
  isActive    Boolean        @default(true)
  visits      VisitProject[]
}

// Proyectos seleccionados en una visita
model VisitProject {
  id            Int         @id @default(autoincrement())
  visitId       Int
  visit         Visit       @relation(fields: [visitId], references: [id], onDelete: Cascade)
  projectTypeId Int
  projectType   ProjectType @relation(fields: [projectTypeId], references: [id])

  @@unique([visitId, projectTypeId])
}

// Información detallada del proyecto cerrado (la llena el closer)
model ProjectDetails {
  id                Int       @id @default(autoincrement())
  visitId           Int       @unique
  visit             Visit     @relation(fields: [visitId], references: [id])

  // Campos generales
  clientName        String?
  clientEmail       String?
  address           String?
  closingDate       DateTime?
  paymentMethod     String? // efectivo, transferencia, cheque, financiamiento, tarjeta

  // Panel Solar
  solarFinancier    String?
  systemSize        String?
  hoaInfo           String?
  ppwSold           String?
  umbrella          String?
  mpuPanels         String?
  siteSurveyDate    DateTime?
  panelsUp          Boolean @default(false)
  panelsDown        Boolean @default(false)
  panelsPhotoUrl    String?

  // Archivos generales
  electricBillUrl   String?
  closingFormUrl    String?
  homeInsuranceUrl  String?
  homeTitleUrl      String?

  // Techo
  roofType          String? // reemplazo, reparacion, gutters
  roofCostPrice     Float?
  roofSalePrice     Float?
  roofCommission    Float?
  nocUrl            String?
  materialsOrderUrl String?
  roofReportUrl     String?
  propertyPhotosUrl String?

  // Purificador
  waterSystemType   String? // sistema completo, softener, R.O, sistema de pozo
  waterCostPrice    Float?
  waterSalePrice    Float?
  waterCommission   Float?

  // Comisiones de ventas
  primaryRep        String?
  primaryRepCommPct Float?
  secondaryRep      String?
  secondaryRepCommPct Float?
  tertiaryRep       String?
  tertiaryRepCommPct Float?

  // Otros proyectos (genéricos)
  otherCostPrice    Float?
  otherSalePrice    Float?
  otherCommission   Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Objection {
  id       Int    @id @default(autoincrement())
  key      String @unique
  name     String
  nameEn   String?
  color    String @default("#fb7800")
  isActive Boolean @default(true)

  visits VisitObjection[]
}

model VisitObjection {
  visitId     Int
  objectionId Int
  visit       Visit     @relation(fields: [visitId], references: [id], onDelete: Cascade)
  objection   Objection @relation(fields: [objectionId], references: [id], onDelete: Cascade)
  notes       String?

  @@id([visitId, objectionId])
}

// Objeciones del Closer (diferentes a las del Setter)
model CloserObjection {
  id       Int    @id @default(autoincrement())
  key      String @unique
  name     String
  nameEn   String?
  color    String @default("#545f64")
  isActive Boolean @default(true)

  visits VisitCloserObjection[]
}

model VisitCloserObjection {
  visitId           Int
  closerObjectionId Int
  visit             Visit           @relation(fields: [visitId], references: [id], onDelete: Cascade)
  closerObjection   CloserObjection @relation(fields: [closerObjectionId], references: [id], onDelete: Cascade)
  notes             String?

  @@id([visitId, closerObjectionId])
}

model Bill {
  id         Int     @id @default(autoincrement())
  visitId    Int     @unique
  visit      Visit   @relation(fields: [visitId], references: [id])
  imageUrl   String
  phone      String
  clientName String?
  clientEmail String?
  notes      String?
}

model ChatRoom {
  id        Int      @id @default(autoincrement())
  visitId   Int      @unique
  visit     Visit    @relation(fields: [visitId], references: [id])
  createdAt DateTime @default(now())
  messages  ChatMessage[]
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  roomId    Int
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  body      String
  fileUrl   String?
  fileName  String?
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Medallas/Badges
model Badge {
  id                 Int      @id @default(autoincrement())
  name               String
  description        String?
  icon               String? // emoji o nombre de icono
  color              String   @default("#006e00")
  role               String // SETTER o CLOSER
  doorsThreshold     Int? // Para Setter
  prospectsThreshold Int? // Para Setter
  projectsThreshold  Int? // Para Closer
  createdAt          DateTime @default(now())
  userBadges         UserBadge[]
}

model UserBadge {
  id       Int      @id @default(autoincrement())
  userId   Int
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  Int
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

// Metas del negocio
model BusinessGoal {
  id            Int      @id @default(autoincrement())
  period        String // "weekly" o "monthly"
  doorsGoal     Int      @default(0)
  prospectsGoal Int      @default(0)
  projectsGoal  Int      @default(0)
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Patrón semanal para slots del closer
model WeeklyPattern {
  id           Int      @id @default(autoincrement())
  closerId     Int
  closer       User     @relation(fields: [closerId], references: [id], onDelete: Cascade)
  dayOfWeek    Int // 0=domingo, 1=lunes, ..., 6=sábado
  startHour    Int // 9 = 9:00
  endHour      Int // 17 = 17:00
  slotDuration Int      @default(60) // minutos
  isWorkday    Boolean  @default(true)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// Reasignaciones de citas
model SlotReassignment {
  id           Int       @id @default(autoincrement())
  slotId       Int
  slot         CloserSlot @relation(fields: [slotId], references: [id])
  fromCloserId Int
  fromCloser   User      @relation("ReassignFrom", fields: [fromCloserId], references: [id])
  toCloserId   Int?
  toCloser     User?     @relation("ReassignTo", fields: [toCloserId], references: [id])
  reason       String
  status       String    @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
}
